{
  "name": "questions",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "eslint": "eslint src",
    "stylelint": "stylelint src/**/*.{css,less,scss}",
    "biome:lint": "npx @biomejs/biome lint src/",
    "biome:format": "npx @biomejs/biome format --write src/",
    "lint": "pnpm run stylelint && pnpm run biome:lint",
    "export": "next export",
    "lint:fix": "eslint src --fix && stylelint src/**/*.{css,less,scss} --fix && npx @biomejs/biome lint --write src/",
    "prettier": "prettier --write src",
    "prepare": "husky install"
  },
  "dependencies": {
    "@biomejs/biome": "^2.4.6",
    "@hankliu/hankliu-ui": "^0.0.5",
    "@hankliu/icons": "^0.0.2",
    "@hankliu/rc-exception": "^0.0.2",
    "@hankliu/rc-footer": "^0.0.5",
    "@uiw/react-markdown-preview": "^5.1.1",
    "classnames": "^2.5.1",
    "dayjs": "^1.11.19",
    "isomorphic-fetch": "^3.0.0",
    "next": "^14.2.35",
    "nprogress": "^0.2.0",
    "octokit": "^4.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-waypoint": "^10.3.0",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.2.2",
    "@commitlint/config-conventional": "^19.2.2",
    "@hankliu/fabric": "^0.0.1",
    "@types/node": "^20.12.12",
    "@types/react": "^18.2.79",
    "@types/react-dom": "^18.2.25",
    "autoprefixer": "^10.4.19",
    "babel-plugin-import": "^1.13.8",
    "eslint": "^9.1.0",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2",
    "postcss": "^8.4.38",
    "prettier": "^3.2.5",
    "prettier-plugin-tailwindcss": "^0.5.14",
    "sass": "^1.75.0",
    "stylelint": "^16.3.1",
    "tailwindcss": "^3.4.3",
    "tailwindcss-textshadow": "^2.1.3"
  },
  "gitHooks": {
    "pre-commit": "lint-staged"
  }
}
